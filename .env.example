# =====================================================
# Industrial Fighters · variables de entorno
# Copia este archivo a .env.local y rellena los valores
# =====================================================

# Turso (libSQL)
TURSO_DATABASE_URL=libsql://<your-db>.turso.io
TURSO_AUTH_TOKEN=

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# WhatsApp (formato internacional sin "+", p.ej. 34612345678)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=industrialfighters.com
NEXT_PUBLIC_META_PIXEL_ID=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
GOOGLE_SITE_VERIFICATION=

# Email (Resend)
RESEND_API_KEY=

# Auth (se decide en Fase 4 — placeholder)
AUTH_SECRET=
